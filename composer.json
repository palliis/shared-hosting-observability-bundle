{
    "name": "palliis/shared-hosting-observability-bundle",
    "description": "File-spooled logs, traces, metrics helpers, and synthetic checks for Symfony apps on shared hosting.",
    "type": "symfony-bundle",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "monolog/monolog": "^3.5",
        "psr/cache": "^2.0 || ^3.0",
        "psr/log": "^2.0 || ^3.0",
        "symfony/config": "^8.0",
        "symfony/console": "^8.0",
        "symfony/dependency-injection": "^8.0",
        "symfony/event-dispatcher": "^8.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/http-client": "^8.0",
        "symfony/http-client-contracts": "^3.0",
        "symfony/http-foundation": "^8.0",
        "symfony/http-kernel": "^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0 || ^12.0",
        "symfony/cache": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "Palliis\\SharedHostingObservabilityBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Palliis\\SharedHostingObservabilityBundle\\Tests\\": "tests/"
        }
    },
    "extra": {
        "symfony": {
            "bundles": {
                "Palliis\\SharedHostingObservabilityBundle\\SharedHostingObservabilityBundle": ["all"]
            }
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "analyse": "phpstan analyse --memory-limit=-1",
        "cs:fix": "php-cs-fixer fix",
        "cs:check": "php-cs-fixer fix --dry-run --diff",
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
